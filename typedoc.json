{

  "$schema": "https://typedoc-plugin-markdown.org/schema.json",
  "categoryOrder": ["Constructor", "API Access" , "Utilities"],
  "cleanOutputDir": false,
  "disableSources": true,
  "entryPoints": ["src/index.ts"],
  "enumMembersFormat": "table",
  "excludeExternals": true,
  "excludeInternal": true,
  "excludeNotDocumented": false,
  "excludePrivate": true,
  "excludeProtected": true,
  "expandObjects": true,
  "externalSymbolLinkMappings": {

    "typescript": {

      "__type.any":             "https://developer.mozilla.org/en-US/docs/Web/API/AbortSignal/any_static",
      "__type.timeout":         "https://developer.mozilla.org/en-US/docs/Web/API/AbortSignal/timeout_static",
      "AbortSignal":            "https://developer.mozilla.org/en-US/docs/Web/API/AbortSignal",
      "AbortSignal.any":        "https://developer.mozilla.org/en-US/docs/Web/API/AbortSignal/any_static",
      "AbortSignal.timeout":    "https://developer.mozilla.org/en-US/docs/Web/API/AbortSignal/timeout_static",
      "DOMException":           "https://developer.mozilla.org/en-US/docs/Web/API/DOMException",
      "Promise.try":            "https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/Promise/try",
      "PromiseConstructor.try": "https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/Promise/try",
      "Proxy":                  "https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/Proxy",
      "ReadonlyMap":            "https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/Map"
    }
  },
  "gitRevision": "main",
  "hideGenerator": true,
  "indexFormat": "table",
  "mergeReadme": true,
  "out": "docs",
  "outputFileStrategy": "members",
  "parametersFormat": "table",
  "plugin": ["typedoc-plugin-markdown"],
  "propertiesFormat": "table",
  "readme": "docs/Overview.md",
  "textContentMappings": {

    "breadcrumbs.home": "Home"
  },
  "typeDeclarationFormat": "table",
  "useCodeBlocks": true,
  "validation": {

    "invalidLink": true,
    "notExported": false
  }
}
